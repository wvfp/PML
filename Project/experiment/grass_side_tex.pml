; grass_side_tex.pml — 草地侧面纯材质定义 (无几何)
; 只提供颜色数据和分层比例, 不包含任何 polygon/shape

(provide left-material right-material bottom-material)

; ═══════════════════════════════════════════════════════════════════════════════
; 左侧面材质: ((颜色 . v上限) ...)
; v=0 是顶边, v=1 是底边
; 从顶到底的层: 草亮边 → 草层 → 腐殖土 → 心土 → 岩石
; ═══════════════════════════════════════════════════════════════════════════════

(define left-material
  '((rock    "#6B5B4A" 1.00)   ; 岩石底层 (35-100%)
    (subsoil "#8B6B45" 0.75)   ; 心土层   (35-75%)
    (humus   "#4A3520" 0.35)   ; 腐殖土   (10-35%)
    (grass   "#2D6B1E" 0.10)   ; 草层     (3-10%)
    (bright  "#3A8A2A" 0.03))) ; 草亮边   (0-3%)

; ══════════════════════════════════════════════════════════════════════════════
; 右侧面材质 (偏暗光照)
; ═══════════════════════════════════════════════════════════════════════════════

(define right-material
  '((rock    "#5A4A3A" 1.00)
    (subsoil "#7A5B35" 0.75)
    (humus   "#3A2815" 0.35)
    (grass   "#225A16" 0.08)
    (bright  "#2A6E1C" 0.02)))

; ══════════════════════════════════════════════════════════════════════════════
; 底面材质
; ═══════════════════════════════════════════════════════════════════════════════

(define bottom-material
  '((rock    "#5A4A3A" 1.00)
    (subsoil "#7A5B35" 0.75)
    (humus   "#3A2815" 0.35)
    (grass   "#225A16" 0.08)
    (bright  "#2A6E1C" 0.02)))
