;; PML Standard Library — sprites/eyes.pml
;; Anime eyes component
;;
;; Usage:
;;   (anime-eyes :style 'shoujo :color "#4a90d9" :size 1.0 :spacing 1.0
;;               :highlight #t :lashes #t)
;;
;; Parameters:
;;   :style    — shoujo | shounen | round | sharp | sleepy | closed
;;   :color    — iris color (any color value)
;;   :size     — 0.5 to 3.0 (default: 1.0)
;;   :spacing  — 0.5 to 2.0 (default: 1.0)
;;   :highlight — #t | #f (default: #t)
;;   :lashes   — #t | #f (default: #t)

(provide anime-eyes)
