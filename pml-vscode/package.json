{
  "name": "pml-vscode",
  "displayName": "PML — Picture Markup Language",
  "description": "Syntax highlighting, live preview, and language server for PML (code-to-image DSL)",
  "version": "0.1.0",
  "publisher": "wvfp",
  "license": "MIT",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization",
    "Linters"
  ],
  "keywords": ["pml", "pml-markup", "image-generation", "dsl", "lisp"],
  "homepage": "https://github.com/wvfp/PML",
  "repository": {
    "type": "git",
    "url": "https://github.com/wvfp/PML.git"
  },
  "activationEvents": [
    "onLanguage:pml",
    "onCommand:pml.preview",
    "onCommand:pml.preview.save"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "pml",
        "aliases": ["PML", "pml"],
        "extensions": [".pml"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "pml",
        "scopeName": "source.pml",
        "path": "./syntaxes/pml.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "pml.preview",
        "title": "PML: Open Preview"
      },
      {
        "command": "pml.preview.save",
        "title": "PML: Save Preview Image As..."
      }
    ],
    "keybindings": [
      {
        "command": "pml.preview",
        "key": "ctrl+shift+p",
        "mac": "cmd+shift+p",
        "when": "editorLangId == pml"
      }
    ],
    "configuration": {
      "title": "PML",
      "properties": {
        "pml.preview.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh the preview on file changes"
        },
        "pml.preview.backgroundColor": {
          "type": "string",
          "default": "#1a1a2e",
          "description": "Background color for the preview canvas (CSS color or 'transparent')"
        },
        "pml.lsp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the PML language server (diagnostics, completions, hover)"
        },
        "pml.lsp.serverPath": {
          "type": "string",
          "default": "",
          "description": "Path to a custom LSP server executable. Leave empty to use the bundled one."
        },
        "pml.render.format": {
          "type": "string",
          "default": "png",
          "enum": ["png", "gif"],
          "description": "Default output format for the preview"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./tsconfig.json",
    "watch": "tsc -watch -p ./tsconfig.json"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
