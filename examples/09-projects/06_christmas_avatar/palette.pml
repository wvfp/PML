; palette.pml - 颜色定义
; 配色参考：卡通头像风格（红色圣诞帽 + 灰发 + 绿眼 + 红衣）

(provide
  c-bg
  c-stroke
  c-hat
  c-hat-shadow
  c-hat-fur
  c-hair
  c-hair-shadow
  c-hair-highlight
  c-skin
  c-skin-shadow
  c-cheek
  c-iris
  c-iris-dark
  c-eye-white
  c-eyelash
  c-mouth
  c-tongue
  c-clothes
  c-clothes-shadow
  c-clothes-rib)

(define c-bg          "#E8E9ED")
(define c-stroke      "#1A1A1A")
(define c-hat         "#E63A3A")
(define c-hat-shadow  "#B02424")
(define c-hat-fur     "#FFFFFF")
(define c-hair        "#B5B7C2")
(define c-hair-shadow "#8B8D99")
(define c-hair-highlight "#C4D9E8")
(define c-skin        "#FFD8C8")
(define c-skin-shadow "#E5B5A5")
(define c-cheek       "#FF8A8A")
(define c-iris        "#3FC7B8")
(define c-iris-dark   "#1E8070")
(define c-eye-white   "#FFFFFF")
(define c-eyelash     "#1A1A1A")
(define c-mouth       "#C92A2A")
(define c-tongue      "#FF6580")
(define c-clothes     "#E63A3A")
(define c-clothes-shadow "#A82222")
(define c-clothes-rib "#8A1A1A")
